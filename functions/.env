# Firebase Cloud Functions runtime env (gen2).
# Firebase only loads .env files located in the functions source dir (firebase.json: functions.source = "functions").
#
# ⚠️ THIS FILE IS COMMITTED TO GIT — deliberately, so CI deploys carry this config.
# NON-SECRET CONFIG ONLY. Never put API keys, tokens, or passwords here.
# Secrets go in Firebase Secret Manager: firebase functions:secrets:set NAME

# Swiss Ephemeris sidecar (Cloud Run). Without this, ephemeris.js falls back to
# http://localhost:8000/calculate, which does not exist in the serverless container,
# so calibration fails with ECONNREFUSED and /api/health reports calibrated:false.
EPHEMERIS_URL=https://ephemeris-service-720107337435.us-central1.run.app/calculate

# Practitioner allowlist (comma-separated emails). The gate in routes/chat.js
# FAILS CLOSED: if this is empty/unset, /analyze, /follow-up and /slides
# reject every request in production.
PRACTITIONER_EMAILS=tsgoddessfireaf@gmail.com

# Stripe price IDs (non-secret identifiers; the secret key lives in Secret Manager).
# Fill these in with the real price IDs from the Stripe dashboard:
# STRIPE_PRICE_ID=price_...
# STRIPE_BOOKING_PRICE_ID=price_...

# Forces production behavior (CORS allowlist, Stripe/booking redirect base URL,
# practitioner-gate dev-bypass disabled) when Firebase Functions doesn't set this
# automatically. W4 audit fix — verify this still applies after any Firebase SDK upgrade.
NODE_ENV=production
