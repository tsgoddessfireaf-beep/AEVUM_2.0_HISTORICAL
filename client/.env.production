# Loaded by `vite build` (production mode). Points the browser at the API
# Cloud Function's DIRECT URL so the SSE judgment stream bypasses Firebase
# Hosting's buffered ~60s rewrite cap. Do NOT set this in .env.local (dev),
# or the dev browser will be CORS-blocked by the production function — dev
# uses the Vite proxy instead.
VITE_API_BASE_URL=https://us-central1-flutter-ai-playground-f880c.cloudfunctions.net/api
