# Copy this file to .env.local and fill in your Firebase web app config.
# Find these at: console.firebase.google.com → Project Settings → Your apps → Web app → Config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated Google account emails allowed to generate client teaching
# slides and record voice narration (the "Client Package" panel on Results).
VITE_PRACTITIONER_EMAILS=
