rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidChart(data) {
      return data.keys().hasAll(['name', 'data', 'request', 'ownerId'])
        && data.keys().size() >= 4
        && data.name is string && data.name.size() <= 100
        && data.ownerId == request.auth.uid
        && data.data is map
        && data.request is map;
    }

    function isValidTransit(data) {
      return data.keys().hasAll(['key', 'data'])
        && data.key is string && data.key.size() <= 200
        && data.data is map;
    }

    match /users/{userId}/charts/{chartId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidChart(incoming())
        && (incoming().createdAt == request.time || incoming().createdAt == null);
        
      allow update: if isOwner(userId)
        && isValidChart(incoming())
        && incoming().ownerId == existing().ownerId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'request', 'updatedAt', 'createdAt'])
        );
        
      allow delete: if isOwner(userId);
    }

    match /transits/{cacheId} {
      allow get: if isSignedIn() && isValidId(cacheId);
      allow list: if false;
      
      allow create: if isSignedIn() 
        && isValidId(cacheId)
        && isValidTransit(incoming());
        
      allow update: if false;
      allow delete: if false;
    }
  }
}
